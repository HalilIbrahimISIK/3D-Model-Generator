    "        \"---\\n\",\n",
    "        \"## 🛠️ Sorun Giderme\\n\",\n",
    "        \"\\n\",\n",
    "        \"### `spconv` import hatası\\n\",\n",
    "        \"```python\\n\",\n",
    "        \"# CUDA sürümünüzü kontrol edin\\n\",\n",
    "        \"import torch; print(torch.version.cuda)\\n\",\n",
    "        \"# Uygun spconv'u kurun\\n\",\n",
