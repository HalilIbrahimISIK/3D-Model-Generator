    "    },\n",
    "    \"accelerator\": \"GPU\"\n",
    "  },\n",
    "  \"cells\": [\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"# 🤖 3D Model Generator — TRELLIS + Groq LLM\\n\",\n",
    "        \"\\n\",\n",
    "        \"**Google Colab üzerinde çalışan versiyon.**  \\n\",\n",
    "        \"Masaüstü PyQt6 arayüzü yerine **Gradio** kullanılmaktadır.\\n\",\n",
    "        \"\\n\",\n",
    "        \"---\\n\",\n",
    "        \"\\n\",\n",
    "        \"## ✅ Ön Koşullar\\n\",\n",
    "        \"\\n\",\n",
    "        \"1. **GPU Etkinleştir:** `Çalışma Zamanı → Çalışma zamanı türünü değiştir → T4 GPU`\\n\",\n",
    "        \"2. Hücreleri **sırasıyla** çalıştırın\\n\",\n",
    "        \"3. Kurulum hücresi bittikten sonra **runtime restart** yapın (uyarı görünecek)\\n\",\n",
    "        \"\\n\",\n",
    "        \"---\\n\",\n",
    "        \"\\n\",\n",
    "        \"| Bileşen | Teknoloji |\\n\",\n",
    "        \"|---|---|\\n\",\n",
    "        \"| 3D Dönüştürme | TRELLIS (microsoft/TRELLIS-image-large) |\\n\",\n",
    "        \"| LLM | Groq API (llama-3.3-70b) |\\n\",\n",
    "        \"| Arayüz | Gradio |\\n\",\n",
    "        \"| GPU | NVIDIA T4 / A100 (Colab) |\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 1 — GPU Kontrolü\\n\",\n",
    "        \"> **Önce GPU'nun aktif olduğunu doğrulayın!**\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"import torch\\n\",\n",
    "        \"\\n\",\n",
    "        \"if not torch.cuda.is_available():\\n\",\n",
    "        \"    raise RuntimeError(\\n\",\n",
    "        \"        \\\"❌ GPU bulunamadı!\\\\n\\\"\\n\",\n",
    "        \"        \\\"Çalışma Zamanı → Çalışma zamanı türünü değiştir → T4 GPU seçin\\\"\\n\",\n",
    "        \"    )\\n\",\n",
    "        \"\\n\",\n",
    "        \"gpu_name = torch.cuda.get_device_name(0)\\n\",\n",
    "        \"cuda_ver = torch.version.cuda\\n\",\n",
    "        \"vram_gb  = torch.cuda.get_device_properties(0).total_memory / 1e9\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(f\\\"✅ GPU   : {gpu_name}\\\")\\n\",\n",
    "        \"print(f\\\"✅ CUDA  : {cuda_ver}\\\")\\n\",\n",
    "        \"print(f\\\"✅ VRAM  : {vram_gb:.1f} GB\\\")\\n\",\n",
    "        \"print(f\\\"✅ Torch : {torch.__version__}\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 2 — Bağımlılık Kurulumu\\n\",\n",
    "        \"\\n\",\n",
    "        \"> ⏱️ **~5-10 dakika** sürebilir.  \\n\",\n",
    "        \"> Kurulum bittikten sonra **runtime'ı yeniden başlatın.**\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"import subprocess, sys, torch\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── CUDA sürümüne göre spconv paketi belirle ──────────────\\n\",\n",
    "        \"cuda_ver = torch.version.cuda          # örn: \\\"12.1\\\" veya \\\"11.8\\\"\\n\",\n",
    "        \"parts    = cuda_ver.split(\\\".\\\")\\n\",\n",
    "        \"cuda_tag = f\\\"cu{parts[0]}{parts[1]}\\\"   # \\\"cu121\\\", \\\"cu118\\\", \\\"cu124\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"# Bilinen spconv build'leri\\n\",\n",
    "        \"known = {\\\"cu124\\\", \\\"cu121\\\", \\\"cu118\\\", \\\"cu117\\\", \\\"cu116\\\"}\\n\",\n",
    "        \"if cuda_tag not in known:\\n\",\n",
    "        \"    cuda_tag = \\\"cu121\\\"   # varsayılan fallback\\n\",\n",
    "        \"\\n\",\n",
    "        \"spconv_pkg = f\\\"spconv-{cuda_tag}\\\"\\n\",\n",
    "        \"print(f\\\"CUDA {cuda_ver} → {spconv_pkg} kurulacak\\\\n\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Paket listesi ─────────────────────────────────────────\\n\",\n",
    "        \"packages = [\\n\",\n",
    "        \"    spconv_pkg,\\n\",\n",
    "        \"    \\\"easydict\\\",\\n\",\n",
    "        \"    \\\"imageio\\\",\\n\",\n",
    "        \"    \\\"imageio-ffmpeg\\\",\\n\",\n",
    "        \"    \\\"plyfile\\\",\\n\",\n",
    "        \"    \\\"rembg\\\",\\n\",\n",
    "        \"    \\\"onnxruntime-gpu\\\",\\n\",\n",
    "        \"    \\\"xatlas\\\",\\n\",\n",
    "        \"    \\\"trimesh\\\",\\n\",\n",
    "        \"    \\\"pymeshfix\\\",\\n\",\n",
    "        \"    \\\"igraph\\\",\\n\",\n",
    "        \"    \\\"transformers>=4.35\\\",\\n\",\n",
    "        \"    \\\"diffusers\\\",\\n\",\n",
    "        \"    \\\"accelerate\\\",\\n\",\n",
    "        \"    \\\"groq\\\",\\n\",\n",
    "        \"    \\\"gradio>=4.0\\\",\\n\",\n",
    "        \"    \\\"plotly\\\",\\n\",\n",
    "        \"    \\\"jaxtyping\\\",\\n\",\n",
    "        \"    \\\"einops\\\",\\n\",\n",
    "        \"]\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"Paketler kuruluyor...\\\")\\n\",\n",
    "        \"for pkg in packages:\\n\",\n",
    "        \"    result = subprocess.run(\\n\",\n",
    "        \"        [sys.executable, \\\"-m\\\", \\\"pip\\\", \\\"install\\\", pkg, \\\"-q\\\"],\\n\",\n",
    "        \"        capture_output=True, text=True\\n\",\n",
    "        \"    )\\n\",\n",
    "        \"    icon = \\\"✅\\\" if result.returncode == 0 else \\\"⚠️\\\"\\n\",\n",
    "        \"    print(f\\\"  {icon} {pkg}\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"\\\\n\\\" + \\\"=\\\"*50)\\n\",\n",
    "        \"print(\\\"✅ Kurulum tamamlandı!\\\")\\n\",\n",
    "        \"print(\\\"=\\\"*50)\\n\",\n",
    "        \"print(\\\"⚠️  ŞIMDI RUNTIME'I YENİDEN BAŞLATIN:\\\")\\n\",\n",
    "        \"print(\\\"   Çalışma Zamanı → Çalışma Zamanını Yeniden Başlat\\\")\\n\",\n",
    "        \"print(\\\"   Yeniden başlattıktan sonra Adım 3'ten devam edin.\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"---\\n\",\n",
    "        \"## ⚠️ Runtime Yeniden Başlatıldıktan Sonra Buradan Devam Edin\\n\",\n",
    "        \"---\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 3 — Proje Kurulumu\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"import os, sys\\n\",\n",
    "        \"\\n\",\n",
    "        \"# TRELLIS için ortam değişkenleri\\n\",\n",
    "        \"os.environ['SPCONV_ALGO']  = 'native'   # İlk çalıştırmada benchmark yapma\\n\",\n",
    "        \"os.environ['ATTN_BACKEND'] = 'sdpa'     # flash-attn yerine PyTorch built-in\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Projeyi GitHub'dan klonla ────────────────────────────\\n\",\n",
    "        \"PROJECT_DIR = '/content/3D-Model-Generator'\\n\",\n",
    "        \"\\n\",\n",
    "        \"# TODO: kendi GitHub repo adresinizi buraya yazın\\n\",\n",
    "        \"GITHUB_REPO = 'https://github.com/HalilIbrahimISIK/3D-Model-Generator.git'\\n\",\n",
    "        \"\\n\",\n",
    "        \"if not os.path.exists(PROJECT_DIR):\\n\",\n",
    "        \"    print(\\\"GitHub'dan klonlanıyor...\\\")\\n\",\n",
    "        \"    os.system(f'git clone {GITHUB_REPO} {PROJECT_DIR}')\\n\",\n",
    "        \"    print(\\\"✅ Proje klonlandı\\\")\\n\",\n",
    "        \"else:\\n\",\n",
    "        \"    print(\\\"✅ Proje zaten mevcut\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Python yollarını ayarla ───────────────────────────────\\n\",\n",
    "        \"for path in [PROJECT_DIR, f'{PROJECT_DIR}/trellis_lib']:\\n\",\n",
    "        \"    if path not in sys.path:\\n\",\n",
    "        \"        sys.path.insert(0, path)\\n\",\n",
    "        \"\\n\",\n",
    "        \"os.chdir(PROJECT_DIR)\\n\",\n",
    "        \"print(f\\\"✅ Çalışma dizini: {os.getcwd()}\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── GPU doğrula ───────────────────────────────────────────\\n\",\n",
    "        \"import torch\\n\",\n",
    "        \"assert torch.cuda.is_available(), \\\"GPU bulunamadı!\\\"\\n\",\n",
    "        \"print(f\\\"✅ GPU : {torch.cuda.get_device_name(0)}\\\")\\n\",\n",
    "        \"print(f\\\"✅ CUDA: {torch.version.cuda}\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 4 — TRELLIS Modelini Yükle\\n\",\n",
    "        \"\\n\",\n",
    "        \"> ⏱️ İlk çalıştırmada model HuggingFace'den indirilir (~2 GB).  \\n\",\n",
    "        \"> Sonraki çalıştırmalarda cache'den okunur.\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"from trellis.pipelines import TrellisImageTo3DPipeline\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"TRELLIS modeli yükleniyor...\\\")\\n\",\n",
    "        \"print(\\\"(İlk seferde ~2 GB indirilir, sabırlı olun)\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"pipeline = TrellisImageTo3DPipeline.from_pretrained(\\\"microsoft/TRELLIS-image-large\\\")\\n\",\n",
    "        \"pipeline.cuda()\\n\",\n",
    "        \"\\n\",\n",
    "        \"print(\\\"\\\\n✅ TRELLIS modeli hazır ve GPU'da!\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 5 — Groq API Anahtarı (İsteğe Bağlı)\\n\",\n",
    "        \"\\n\",\n",
    "        \"LLM chat özelliği için Groq API anahtarı gerekmektedir.  \\n\",\n",
    "        \"Ücretsiz anahtar: https://console.groq.com/\\n\",\n",
    "        \"\\n\",\n",
    "        \"STL dönüştürme için API anahtarı **gerekli değildir.**\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"# Groq API anahtarınızı buraya girin (isteğe bağlı)\\n\",\n",
    "        \"GROQ_API_KEY = \\\"\\\"  # gsk_xxxxxxxxxxxxxxxx\\n\",\n",
    "        \"\\n\",\n",
    "        \"# Veya Colab Secrets'tan okuyun (önerilir):\\n\",\n",
    "        \"# from google.colab import userdata\\n\",\n",
    "        \"# GROQ_API_KEY = userdata.get('GROQ_API_KEY')\\n\",\n",
    "        \"\\n\",\n",
    "        \"if GROQ_API_KEY:\\n\",\n",
    "        \"    os.environ['GROQ_API_KEY'] = GROQ_API_KEY\\n\",\n",
    "        \"    print(\\\"✅ Groq API anahtarı ayarlandı\\\")\\n\",\n",
    "        \"else:\\n\",\n",
    "        \"    print(\\\"⚠️  Groq API anahtarı girilmedi — LLM chat devre dışı\\\")\\n\",\n",
    "        \"    print(\\\"   STL dönüştürme yine de çalışacak\\\")\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"markdown\",\n",
    "      \"metadata\": {},\n",
    "      \"source\": [\n",
    "        \"## 📌 Adım 6 — Uygulamayı Başlat\\n\",\n",
    "        \"\\n\",\n",
    "        \"> Hücreyi çalıştırdıktan sonra **public link** oluşturulacak.  \\n\",\n",
    "        \"> Link **72 saat** geçerlidir.\"\n",
    "      ]\n",
    "    },\n",
    "    {\n",
    "      \"cell_type\": \"code\",\n",
    "      \"metadata\": {},\n",
    "      \"outputs\": [],\n",
    "      \"execution_count\": null,\n",
    "      \"source\": [\n",
    "        \"import gradio as gr\\n\",\n",
    "        \"import trimesh\\n\",\n",
    "        \"import numpy as np\\n\",\n",
    "        \"from PIL import Image\\n\",\n",
    "        \"import torch, os, tempfile, datetime\\n\",\n",
    "        \"import plotly.graph_objects as go\\n\",\n",
    "        \"\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Yardımcı: Gradio dosya yolunu al ─────────────────────\\n\",\n",
    "        \"def _path(f):\\n\",\n",
    "        \"    \\\"\\\"\\\"Gradio dosya objesinden path string'i çıkar.\\\"\\\"\\\"\\n\",\n",
    "        \"    if f is None:\\n\",\n",
    "        \"        return None\\n\",\n",
    "        \"    if isinstance(f, str):\\n\",\n",
    "        \"        return f\\n\",\n",
    "        \"    if isinstance(f, dict):\\n\",\n",
    "        \"        return f.get(\\\"name\\\") or f.get(\\\"path\\\", \\\"\\\")\\n\",\n",
    "        \"    if hasattr(f, \\\"name\\\"):\\n\",\n",
    "        \"        return f.name\\n\",\n",
    "        \"    return str(f)\\n\",\n",
    "        \"\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── STL dönüştürme fonksiyonu ─────────────────────────────\\n\",\n",
    "        \"def convert_to_stl(files, steps, cfg_strength, progress=gr.Progress()):\\n\",\n",
    "        \"    if not files:\\n\",\n",
    "        \"        return None, None, \\\"❌ Görsel yüklenmedi. Lütfen en az 1 görsel seçin.\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"    paths = [_path(f) for f in files if _path(f)]\\n\",\n",
    "        \"    n = len(paths)\\n\",\n",
    "        \"\\n\",\n",
    "        \"    try:\\n\",\n",
    "        \"        progress(0.1, desc=\\\"Görseller yükleniyor...\\\")\\n\",\n",
    "        \"        images = [Image.open(p).convert(\\\"RGB\\\") for p in paths]\\n\",\n",
    "        \"\\n\",\n",
    "        \"        progress(0.3, desc=f\\\"{n} görsel ile 3D yeniden yapılandırma...\\\")\\n\",\n",
    "        \"        with torch.no_grad():\\n\",\n",
    "        \"            if n == 1:\\n\",\n",
    "        \"                outputs = pipeline.run(\\n\",\n",
    "        \"                    images[0],\\n\",\n",
    "        \"                    seed=42,\\n\",\n",
    "        \"                    preprocess_image=True,\\n\",\n",
    "        \"                    sparse_structure_sampler_params={\\\"steps\\\": int(steps), \\\"cfg_strength\\\": float(cfg_strength)},\\n\",\n",
    "        \"                    slat_sampler_params={\\\"steps\\\": int(steps), \\\"cfg_strength\\\": 3.0},\\n\",\n",
    "        \"                )\\n\",\n",
    "        \"            else:\\n\",\n",
    "        \"                outputs = pipeline.run_multi_image(\\n\",\n",
    "        \"                    images,\\n\",\n",
    "        \"                    seed=42,\\n\",\n",
    "        \"                    preprocess_image=True,\\n\",\n",
    "        \"                    sparse_structure_sampler_params={\\\"steps\\\": int(steps), \\\"cfg_strength\\\": float(cfg_strength)},\\n\",\n",
    "        \"                    slat_sampler_params={\\\"steps\\\": int(steps), \\\"cfg_strength\\\": 3.0},\\n\",\n",
    "        \"                )\\n\",\n",
    "        \"\\n\",\n",
    "        \"        progress(0.8, desc=\\\"Mesh çıkarılıyor...\\\")\\n\",\n",
    "        \"        mesh_result = outputs[\\\"mesh\\\"][0]\\n\",\n",
    "        \"        vertices = mesh_result.vertices.cpu().float().numpy()\\n\",\n",
    "        \"        faces    = mesh_result.faces.cpu().numpy()\\n\",\n",
    "        \"        tri_mesh = trimesh.Trimesh(vertices=vertices, faces=faces)\\n\",\n",
    "        \"\\n\",\n",
    "        \"        progress(0.9, desc=\\\"STL kaydediliyor...\\\")\\n\",\n",
    "        \"        ts       = datetime.datetime.now().strftime(\\\"%Y%m%d_%H%M%S\\\")\\n\",\n",
    "        \"        tag      = f\\\"multi{n}\\\" if n > 1 else \\\"single\\\"\\n\",\n",
    "        \"        stl_path = f\\\"/content/model_{tag}_{ts}.stl\\\"\\n\",\n",
    "        \"        tri_mesh.export(stl_path)\\n\",\n",
    "        \"\\n\",\n",
    "        \"        # ── 3D Plotly önizleme ────────────────────────────\\n\",\n",
    "        \"        fig = go.Figure(data=[go.Mesh3d(\\n\",\n",
    "        \"            x=vertices[:, 0], y=vertices[:, 1], z=vertices[:, 2],\\n\",\n",
    "        \"            i=faces[:, 0], j=faces[:, 1], k=faces[:, 2],\\n\",\n",
    "        \"            opacity=0.75,\\n\",\n",
    "        \"            colorscale=\\\"Viridis\\\",\\n\",\n",
    "        \"            intensity=vertices[:, 2],\\n\",\n",
    "        \"            showscale=False,\\n\",\n",
    "        \"        )])\\n\",\n",
    "        \"        fig.update_layout(\\n\",\n",
    "        \"            scene=dict(\\n\",\n",
    "        \"                aspectmode=\\\"data\\\",\\n\",\n",
    "        \"                xaxis=dict(showgrid=False, zeroline=False),\\n\",\n",
    "        \"                yaxis=dict(showgrid=False, zeroline=False),\\n\",\n",
    "        \"                zaxis=dict(showgrid=False, zeroline=False),\\n\",\n",
    "        \"                bgcolor=\\\"#0f0f1a\\\",\\n\",\n",
    "        \"            ),\\n\",\n",
    "        \"            paper_bgcolor=\\\"#0f0f1a\\\",\\n\",\n",
    "        \"            font_color=\\\"white\\\",\\n\",\n",
    "        \"            title=dict(\\n\",\n",
    "        \"                text=f\\\"3D Model — {n} görsel ({'çok açı modu' if n > 1 else 'tek görsel'})\\\",\\n\",\n",
    "        \"                font_color=\\\"#c8b8ff\\\",\\n\",\n",
    "        \"            ),\\n\",\n",
    "        \"            height=500,\\n\",\n",
    "        \"            margin=dict(l=0, r=0, t=40, b=0),\\n\",\n",
    "        \"        )\\n\",\n",
    "        \"\\n\",\n",
    "        \"        size_kb = os.path.getsize(stl_path) / 1024\\n\",\n",
    "        \"        size_str = f\\\"{size_kb:.0f} KB\\\" if size_kb < 1024 else f\\\"{size_kb/1024:.2f} MB\\\"\\n\",\n",
    "        \"        mode_str = f\\\"{n} görsel — çok açı modu 🎯\\\" if n > 1 else \\\"1 görsel — tek mod\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"        status = (\\n\",\n",
    "        \"            f\\\"✅ Dönüştürme tamamlandı!\\\\n\\\"\\n\",\n",
    "        \"            f\\\"📄 Dosya : {os.path.basename(stl_path)}\\\\n\\\"\\n\",\n",
    "        \"            f\\\"📦 Boyut : {size_str}\\\\n\\\"\\n\",\n",
    "        \"            f\\\"🔺 Mesh  : {len(vertices):,} vertex · {len(faces):,} yüz\\\\n\\\"\\n\",\n",
    "        \"            f\\\"🖼️ Mod   : {mode_str}\\\"\\n\",\n",
    "        \"        )\\n\",\n",
    "        \"        progress(1.0, desc=\\\"Tamamlandı!\\\")\\n\",\n",
    "        \"        return stl_path, fig, status\\n\",\n",
    "        \"\\n\",\n",
    "        \"    except Exception as e:\\n\",\n",
    "        \"        return None, None, f\\\"❌ Hata:\\\\n{str(e)}\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── LLM chat fonksiyonu ───────────────────────────────────\\n\",\n",
    "        \"def llm_chat(message, history, api_key, image_file):\\n\",\n",
    "        \"    if not message.strip():\\n\",\n",
    "        \"        return history, \\\"\\\"\\n\",\n",
    "        \"    if not api_key.strip():\\n\",\n",
    "        \"        history.append({\\\"role\\\": \\\"assistant\\\", \\\"content\\\": \\\"❌ Groq API anahtarı girilmedi.\\\"})\\n\",\n",
    "        \"        return history, \\\"\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"    try:\\n\",\n",
    "        \"        from groq import Groq\\n\",\n",
    "        \"        import base64\\n\",\n",
    "        \"\\n\",\n",
    "        \"        client  = Groq(api_key=api_key.strip())\\n\",\n",
    "        \"        content = []\\n\",\n",
    "        \"\\n\",\n",
    "        \"        # Görsel varsa vision modeli kullan\\n\",\n",
    "        \"        if image_file:\\n\",\n",
    "        \"            img_path  = _path(image_file)\\n\",\n",
    "        \"            ext       = os.path.splitext(img_path)[1].lower()\\n\",\n",
    "        \"            mime      = {\\\"jpg\\\": \\\"image/jpeg\\\", \\\"jpeg\\\": \\\"image/jpeg\\\", \\\"png\\\": \\\"image/png\\\"}.get(ext[1:], \\\"image/jpeg\\\")\\n\",\n",
    "        \"            with open(img_path, \\\"rb\\\") as f:\\n\",\n",
    "        \"                b64 = base64.b64encode(f.read()).decode()\\n\",\n",
    "        \"            content = [\\n\",\n",
    "        \"                {\\\"type\\\": \\\"text\\\", \\\"text\\\": message},\\n\",\n",
    "        \"                {\\\"type\\\": \\\"image_url\\\", \\\"image_url\\\": {\\\"url\\\": f\\\"data:{mime};base64,{b64}\\\"}},\\n\",\n",
    "        \"            ]\\n\",\n",
    "        \"            model = \\\"llama-3.2-11b-vision-preview\\\"\\n\",\n",
    "        \"        else:\\n\",\n",
    "        \"            content = message\\n\",\n",
    "        \"            model   = \\\"llama-3.3-70b-versatile\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"        msgs = [\\n\",\n",
    "        \"            {\\\"role\\\": \\\"system\\\", \\\"content\\\": (\\n\",\n",
    "        \"                \\\"Sen 3D model asistanısın. Görselleri analiz eder, \\\"\\n\",\n",
    "        \"                \\\"3D baskı için tavsiyelerde bulunursun. \\\"\\n\",\n",
    "        \"                \\\"Türkçe ve İngilizce konuşabilirsin.\\\"\\n\",\n",
    "        \"            )}\\n\",\n",
    "        \"        ]\\n\",\n",
    "        \"        for h in history:\\n\",\n",
    "        \"            msgs.append({\\\"role\\\": h[\\\"role\\\"], \\\"content\\\": h[\\\"content\\\"]})\\n\",\n",
    "        \"        msgs.append({\\\"role\\\": \\\"user\\\", \\\"content\\\": content})\\n\",\n",
    "        \"\\n\",\n",
    "        \"        resp   = client.chat.completions.create(model=model, messages=msgs, max_tokens=1024)\\n\",\n",
    "        \"        answer = resp.choices[0].message.content\\n\",\n",
    "        \"\\n\",\n",
    "        \"        history.append({\\\"role\\\": \\\"user\\\",      \\\"content\\\": message})\\n\",\n",
    "        \"        history.append({\\\"role\\\": \\\"assistant\\\", \\\"content\\\": answer})\\n\",\n",
    "        \"        return history, \\\"\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"    except Exception as e:\\n\",\n",
    "        \"        history.append({\\\"role\\\": \\\"assistant\\\", \\\"content\\\": f\\\"❌ Hata: {str(e)}\\\"})\\n\",\n",
    "        \"        return history, \\\"\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Gradio Arayüzü ────────────────────────────────────────\\n\",\n",
    "        \"CSS = \\\"\\\"\\\"\\n\",\n",
    "        \".gradio-container { max-width: 1200px !important; }\\n\",\n",
    "        \"footer { display: none !important; }\\n\",\n",
    "        \"\\\"\\\"\\\"\\n\",\n",
    "        \"\\n\",\n",
    "        \"with gr.Blocks(css=CSS, title=\\\"3D Model Generator\\\", theme=gr.themes.Soft(\\n\",\n",
    "        \"    primary_hue=\\\"violet\\\", secondary_hue=\\\"purple\\\"\\n\",\n",
    "        \")) as demo:\\n\",\n",
    "        \"\\n\",\n",
    "        \"    gr.Markdown(\\\"\\\"\\\"\\n\",\n",
    "        \"    # 🤖 3D Model Generator — TRELLIS + Groq\\n\",\n",
    "        \"    Tek veya **birden fazla açıdan** görsel yükleyerek STL 3D modeli oluşturun.\\n\",\n",
    "        \"    \\\"\\\"\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"    with gr.Tabs():\\n\",\n",
    "        \"\\n\",\n",
    "        \"        # ── Tab 1: Görsel → STL ───────────────────────────\\n\",\n",
    "        \"        with gr.Tab(\\\"🖼️  Görsel → STL\\\"):\\n\",\n",
    "        \"            with gr.Row():\\n\",\n",
    "        \"                with gr.Column(scale=1):\\n\",\n",
    "        \"                    gr.Markdown(\\\"### 📤 Görsel Yükle\\\")\\n\",\n",
    "        \"                    gr.Markdown(\\n\",\n",
    "        \"                        \\\"💡 **İpucu:** Farklı açılardan çekilen birden fazla görsel \\\"\\n\",\n",
    "        \"                        \\\"yüklemek daha iyi 3D sonuç verir.\\\"\\n\",\n",
    "        \"                    )\\n\",\n",
    "        \"                    images_input = gr.File(\\n\",\n",
    "        \"                        label=\\\"Görsel(ler) — PNG, JPG, WEBP\\\",\\n\",\n",
    "        \"                        file_count=\\\"multiple\\\",\\n\",\n",
    "        \"                        file_types=[\\\".png\\\", \\\".jpg\\\", \\\".jpeg\\\", \\\".webp\\\", \\\".bmp\\\"],\\n\",\n",
    "        \"                    )\\n\",\n",
    "        \"                    with gr.Row():\\n\",\n",
    "        \"                        steps_slider = gr.Slider(\\n\",\n",
    "        \"                            minimum=8, maximum=30, value=12, step=2,\\n\",\n",
    "        \"                            label=\\\"⚡ Diffusion Adımları (fazla = kaliteli ama yavaş)\\\"\\n\",\n",
    "        \"                        )\\n\",\n",
    "        \"                    with gr.Row():\\n\",\n",
    "        \"                        cfg_slider = gr.Slider(\\n\",\n",
    "        \"                            minimum=1.0, maximum=15.0, value=7.5, step=0.5,\\n\",\n",
    "        \"                            label=\\\"🎯 CFG Gücü (görsele sadakat)\\\"\\n\",\n",
    "        \"                        )\\n\",\n",
    "        \"                    convert_btn = gr.Button(\\n\",\n",
    "        \"                        \\\"🔄  STL'e Dönüştür\\\", variant=\\\"primary\\\", size=\\\"lg\\\"\\n\",\n",
    "        \"                    )\\n\",\n",
    "        \"\\n\",\n",
    "        \"                with gr.Column(scale=1):\\n\",\n",
    "        \"                    gr.Markdown(\\\"### 📥 Çıktı\\\")\\n\",\n",
    "        \"                    status_box = gr.Textbox(\\n\",\n",
    "        \"                        label=\\\"Durum\\\", lines=5, interactive=False\\n\",\n",
    "        \"                    )\\n\",\n",
    "        \"                    stl_output = gr.File(\\n\",\n",
    "        \"                        label=\\\"⬇️ STL Dosyası İndir\\\"\\n\",\n",
    "        \"                    )\\n\",\n",
    "        \"\\n\",\n",
    "        \"            preview_plot = gr.Plot(label=\\\"🎲 3D Önizleme (interaktif — döndürmek için sürükleyin)\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"            convert_btn.click(\\n\",\n",
    "        \"                fn=convert_to_stl,\\n\",\n",
    "        \"                inputs=[images_input, steps_slider, cfg_slider],\\n\",\n",
    "        \"                outputs=[stl_output, preview_plot, status_box],\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"\\n\",\n",
    "        \"            # Örnek görseller (TRELLIS assets)\\n\",\n",
    "        \"            gr.Markdown(\\\"### 🐰 Örnek Görseller (TRELLIS veri seti)\\\")\\n\",\n",
    "        \"            gr.Examples(\\n\",\n",
    "        \"                label=\\\"Hazır örnekler — tıklayın ve dönüştürün\\\",\\n\",\n",
    "        \"                examples=[\\n\",\n",
    "        \"                    [[\\\"trellis_lib/assets/example_multi_image/rabbit_1.png\\\",\\n\",\n",
    "        \"                      \\\"trellis_lib/assets/example_multi_image/rabbit_2.png\\\",\\n\",\n",
    "        \"                      \\\"trellis_lib/assets/example_multi_image/rabbit_3.png\\\"], 12, 7.5],\\n\",\n",
    "        \"                    [[\\\"trellis_lib/assets/example_multi_image/mushroom_1.png\\\",\\n\",\n",
    "        \"                      \\\"trellis_lib/assets/example_multi_image/mushroom_2.png\\\",\\n\",\n",
    "        \"                      \\\"trellis_lib/assets/example_multi_image/mushroom_3.png\\\"], 12, 7.5],\\n\",\n",
    "        \"                    [[\\\"trellis_lib/assets/example_image/typical_creature_dragon.png\\\"], 12, 7.5],\\n\",\n",
    "        \"                    [[\\\"trellis_lib/assets/example_image/typical_misc_lantern.png\\\"], 12, 7.5],\\n\",\n",
    "        \"                ],\\n\",\n",
    "        \"                inputs=[images_input, steps_slider, cfg_slider],\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"\\n\",\n",
    "        \"        # ── Tab 2: LLM Chat ───────────────────────────────\\n\",\n",
    "        \"        with gr.Tab(\\\"💬  LLM Chat (Groq)\\\"):\\n\",\n",
    "        \"            gr.Markdown(\\n\",\n",
    "        \"                \\\"AI asistanıyla sohbet edin — görsel yükleyerek analiz de yaptırabilirsiniz.\\\\n\\\"\\n\",\n",
    "        \"                \\\"Ücretsiz API anahtarı: https://console.groq.com/\\\"\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"\\n\",\n",
    "        \"            with gr.Row():\\n\",\n",
    "        \"                api_key_input = gr.Textbox(\\n\",\n",
    "        \"                    label=\\\"🔑 Groq API Anahtarı\\\",\\n\",\n",
    "        \"                    placeholder=\\\"gsk_xxxxxxxxxxxxxxxx\\\",\\n\",\n",
    "        \"                    type=\\\"password\\\",\\n\",\n",
    "        \"                    value=os.environ.get(\\\"GROQ_API_KEY\\\", \\\"\\\"),\\n\",\n",
    "        \"                    scale=3,\\n\",\n",
    "        \"                )\\n\",\n",
    "        \"                chat_image = gr.File(\\n\",\n",
    "        \"                    label=\\\"Görsel Ekle (isteğe bağlı)\\\",\\n\",\n",
    "        \"                    file_types=[\\\".png\\\", \\\".jpg\\\", \\\".jpeg\\\", \\\".webp\\\"],\\n\",\n",
    "        \"                    scale=1,\\n\",\n",
    "        \"                )\\n\",\n",
    "        \"\\n\",\n",
    "        \"            chatbot = gr.Chatbot(\\n\",\n",
    "        \"                label=\\\"Sohbet\\\",\\n\",\n",
    "        \"                height=400,\\n\",\n",
    "        \"                type=\\\"messages\\\",\\n\",\n",
    "        \"                bubble_full_width=False,\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"\\n\",\n",
    "        \"            with gr.Row():\\n\",\n",
    "        \"                msg_input = gr.Textbox(\\n\",\n",
    "        \"                    label=\\\"Mesaj\\\",\\n\",\n",
    "        \"                    placeholder=\\\"3D baskı için ne tavsiye edersiniz?\\\",\\n\",\n",
    "        \"                    scale=4,\\n\",\n",
    "        \"                )\\n\",\n",
    "        \"                send_btn = gr.Button(\\\"Gönder ➤\\\", variant=\\\"primary\\\", scale=1)\\n\",\n",
    "        \"            clear_btn = gr.Button(\\\"🗑  Sohbeti Temizle\\\", size=\\\"sm\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"            send_btn.click(\\n\",\n",
    "        \"                fn=llm_chat,\\n\",\n",
    "        \"                inputs=[msg_input, chatbot, api_key_input, chat_image],\\n\",\n",
    "        \"                outputs=[chatbot, msg_input],\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"            msg_input.submit(\\n\",\n",
    "        \"                fn=llm_chat,\\n\",\n",
    "        \"                inputs=[msg_input, chatbot, api_key_input, chat_image],\\n\",\n",
    "        \"                outputs=[chatbot, msg_input],\\n\",\n",
    "        \"            )\\n\",\n",
    "        \"            clear_btn.click(fn=lambda: ([], \\\"\\\"), outputs=[chatbot, msg_input])\\n\",\n",
    "        \"\\n\",\n",
    "        \"        # ── Tab 3: Bilgi ─────────────────────────────────\\n\",\n",
    "        \"        with gr.Tab(\\\"ℹ️  Bilgi\\\"):\\n\",\n",
    "        \"            import torch\\n\",\n",
    "        \"            vram = torch.cuda.get_device_properties(0).total_memory / 1e9 if torch.cuda.is_available() else 0\\n\",\n",
    "        \"            gr.Markdown(f\\\"\\\"\\\"\\n\",\n",
    "        \"            ## Sistem Bilgisi\\n\",\n",
    "        \"            | Özellik | Değer |\\n\",\n",
    "        \"            |---|---|\\n\",\n",
    "        \"            | GPU | {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'Yok'} |\\n\",\n",
    "        \"            | VRAM | {vram:.1f} GB |\\n\",\n",
    "        \"            | CUDA | {torch.version.cuda} |\\n\",\n",
    "        \"            | PyTorch | {torch.__version__} |\\n\",\n",
    "        \"\\n\",\n",
    "        \"            ## Kullanım Rehberi\\n\",\n",
    "        \"\\n\",\n",
    "        \"            ### Tek Görsel Modu\\n\",\n",
    "        \"            1. **1 görsel** yükleyin\\n\",\n",
    "        \"            2. `pipeline.run()` çağrılır\\n\",\n",
    "        \"            3. Nesnenin net, beyaz/sade arka planlı fotoğrafı ideal\\n\",\n",
    "        \"\\n\",\n",
    "        \"            ### Çok Görsel Modu 🎯\\n\",\n",
    "        \"            1. Aynı nesnenin **2-4 farklı açıdan** fotoğrafını yükleyin\\n\",\n",
    "        \"            2. `pipeline.run_multi_image()` çağrılır  \\n\",\n",
    "        \"            3. Sonuç çok daha gerçekçi ve detaylı olur\\n\",\n",
    "        \"\\n\",\n",
    "        \"            ### Önerilen Fotoğraf Koşulları\\n\",\n",
    "        \"            - ✅ Düz/beyaz arka plan\\n\",\n",
    "        \"            - ✅ İyi aydınlatma\\n\",\n",
    "        \"            - ✅ Nesne merkezi\\n\",\n",
    "        \"            - ✅ Farklı açılar: ön, yan, üst\\n\",\n",
    "        \"            - ❌ Çok karmaşık arka plan\\n\",\n",
    "        \"            - ❌ Çok küçük nesne\\n\",\n",
    "        \"\\n\",\n",
    "        \"            ## STL Dosyasını Kullanmak\\n\",\n",
    "        \"            İndirilen `.stl` dosyasını şu yazılımlarla açabilirsiniz:\\n\",\n",
    "        \"            - **Cura** — 3D baskı dilimleme\\n\",\n",
    "        \"            - **PrusaSlicer** — 3D baskı dilimleme  \\n\",\n",
    "        \"            - **Meshmixer** — Mesh düzenleme\\n\",\n",
    "        \"            - **Blender** — 3D modelleme\\n\",\n",
    "        \"            \\\"\\\"\\\")\\n\",\n",
    "        \"\\n\",\n",
    "        \"# ── Uygulamayı başlat ─────────────────────────────────────\\n\",\n",
    "        \"print(\\\"\\\\n🚀 Gradio uygulaması başlatılıyor...\\\")\\n\",\n",
    "        \"print(\\\"Share link ~72 saat geçerlidir\\\\n\\\")\\n\",\n",
    "        \"demo.launch(share=True, debug=False)\"\n",
    "      ]\n",
